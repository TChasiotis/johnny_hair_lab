generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 1. Πίνακας για τον Διαχειριστή (Admin)
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Εδώ θα αποθηκευτεί το bcrypt hash
  createdAt DateTime @default(now())
}

// 2. Πίνακας για τις Υπηρεσίες του κουρείου
model Service {
  id        String   @id @default(cuid())
  name      String
  duration  String   // π.χ. "30 λ." ή "1 ώ."
  price     String   // π.χ. "12 €" ή "από 40 €"
  createdAt DateTime @default(now())
}

// 3. Πίνακας για τα Προϊόντα (Lavish Care, κλπ)
model Product {
  id        String   @id @default(cuid())
  name      String
  desc      String
  price     String
  img       String   // Το URL της εικόνας
  category  String   // π.χ. "waxes", "shampoos", "prep"
  createdAt DateTime @default(now())
}