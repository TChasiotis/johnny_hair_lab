generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// 1. Πίνακας για τον Διαχειριστή (Admin)
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Εδώ θα αποθηκευτεί το bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Πίνακας για τις Υπηρεσίες του κουρείου
model Service {
  id         String   @id @default(cuid())
  name       String
  nameEn     String   @default("")
  duration   String   // Ένα κοινό πεδίο για όλους (π.χ. "30 min")
  price      String   // Ένα κοινό πεδίο για όλους (π.χ. "15 €")
  sortOrder  Int      @default(0) // Νέο πεδίο για χειροκίνητη ταξινόμηση
  createdAt  DateTime @default(now())
}

// 3. Πίνακας για τα Προϊόντα (Lavish Care, κλπ)
model Product {
  id        String   @id @default(cuid())
  name      String
  price     String
  desc      String
  descEn    String?
  img       String
  category  String
  sortOrder Int      @default(0)
  custom    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ApiLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}